{
  "name": "codex-wechat-connector",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "description": "External connector linking WeChat and local Codex App Server sessions",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/index.ts",
    "test": "tsx --test test/**/*.test.ts",
    "smoke": "tsx src/index.ts codex-smoke",
    "login": "tsx src/index.ts login",
    "wechat": "tsx src/index.ts run",
    "access": "tsx src/index.ts access",
    "reset": "tsx src/index.ts reset",
    "start": "node dist/index.js"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
